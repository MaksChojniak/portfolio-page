{
  "name": "React + Vite + TypeScript",
  "image": "sha256:97c7b3f056f338630b8337ded30c367ae571e1e213b3b541ab862e15522ba664",

  // Forward Vite's dev server port to your host
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    }
  },

  // Run npm install after the container is created
  "postCreateCommand": "npm install",

  // VS Code extensions installed inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },

  // Run as non-root user (built into the node image)
  "remoteUser": "node"
}